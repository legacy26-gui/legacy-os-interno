# Postgres connection string (Vercel Postgres/Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Random secret used to sign session JWTs. Generate with: openssl rand -base64 48
SESSION_SECRET=""

# Secret key required to call GET /api/setup?key=... (one-time initial seed: admin users + contract templates)
SETUP_SECRET=""
